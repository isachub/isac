generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// Holds login credentials only.
// Personal data lives in Profile (1-to-1).
// ─────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  applications Application[]
}

// ─────────────────────────────────────────────
// PROFILE
// One profile per user.
// ─────────────────────────────────────────────
model Profile {
  id          String      @id @default(cuid())
  userId      String      @unique
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal / contact data
  fullName    String?
  phone       String?
  street      String?
  postalCode  String?
  city        String?
  country     String?
  dateOfBirth DateTime?
  nationality String?

  // CV content — free text, used directly in AI prompts
  summary        String?   // short professional summary / about me
  workExperience String?   // work history, one entry per line recommended
  education      String?   // education history, one entry per line recommended
  skills         String?   // technical and professional skills
  languages      String?   // e.g. "Deutsch (B2), Englisch (B1), Arabisch (Muttersprache)"
  certificates   String?   // optional certifications and courses

  targetType  TargetType?
  updatedAt   DateTime    @updatedAt
}

enum TargetType {
  JOB
  AUSBILDUNG
  STUDIUM
}

// ─────────────────────────────────────────────
// APPLICATION
// One document generation request per target.
// AI-generated content added in step 7.
// ─────────────────────────────────────────────
model Application {
  id                    String            @id @default(cuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetType            TargetType
  titleOrRole           String
  companyOrInstitution  String
  targetDescription     String?

  // AI-generated outputs (step 7)
  generatedCv           String?
  generatedLetter       String?

  status                ApplicationStatus @default(DRAFT)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

enum ApplicationStatus {
  DRAFT
  GENERATED
  SENT
}
