# ─── Server ───────────────────────────────────────────────
PORT=3001

# ─── Database ─────────────────────────────────────────────
# Local: postgresql://postgres:postgres@localhost:5432/isac?schema=public
# Railway: provided automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/isac?schema=public

# ─── Auth ─────────────────────────────────────────────────
# Generate a strong secret for production: openssl rand -hex 32
JWT_SECRET=change-this-before-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
# Set to your Vercel frontend URL in production
# e.g. https://isac.vercel.app
FRONTEND_URL=http://localhost:3000

# ─── AI ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
